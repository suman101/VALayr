# ── VALayr Environment Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it is gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# ── Bittensor Network ────────────────────────────────────────────────────────
BITTENSOR_NETWORK=finney
NETUID=1
WALLET_NAME=default
WALLET_HOTKEY=default

# ── Validator Settings ───────────────────────────────────────────────────────
VALIDATOR_ID=validator-0

# ── Anvil Deterministic Config ───────────────────────────────────────────────
ANVIL_BLOCK_TIMESTAMP=1700000000
ANVIL_BLOCK_NUMBER=18000000
ANVIL_GAS_LIMIT=30000000
ANVIL_CHAIN_ID=31337

# ── Deployment ───────────────────────────────────────────────────────────────
# DEPLOYER_KEY=  # Set for testnet/mainnet deployments. NEVER use Anvil default key in production.
# RPC_URL=http://127.0.0.1:8545
# ETHERSCAN_API_KEY=  # For contract verification

# ── Docker ───────────────────────────────────────────────────────────────────
# PYTHONHASHSEED=0  # Set automatically by containers

# ── Bounty Platform Integration ──────────────────────────────────────────────
# IMMUNEFI_API_KEY=               # Immunefi bug bounty platform API key
# CODE4RENA_API_KEY=              # Code4rena audit contest API key

# ── Anti-Bypass HMAC ─────────────────────────────────────────────────────────
# VALAYR_RECEIPT_HMAC_KEY=        # 32+ byte hex key for receipt integrity
#                                 # If unset, a random key is generated per process

# ── Orchestrator & Sandbox ───────────────────────────────────────────────────
# VALAYR_MAX_CONCURRENT_VALIDATIONS=4   # Max parallel validations per epoch
# VALAYR_EPOCH_COMPUTE_BUDGET=10000     # CPU-seconds budget per epoch
# VALAYR_SUBMISSION_TIMEOUT=300         # Per-submission timeout (seconds)
# VALAYR_REQUIRE_SANDBOX=              # Force Docker sandbox (auto in Docker mode)

# ── Difficulty Phasing ───────────────────────────────────────────────────────
# Controls progressive difficulty across epochs. See validator/utils/difficulty.py.
# Phase 1 (epoch 0–50): synthetic corpus only, no severity floor
# Phase 2 (epoch 51–200): 30% mainnet tasks, severity ≥ 0.1
# Phase 3 (epoch 201+): 60% mainnet tasks, severity ≥ 0.2
# VALAYR_EPOCH_DIFFICULTY_2=51          # Epoch where phase 2 begins
# VALAYR_EPOCH_DIFFICULTY_3=201         # Epoch where phase 3 begins
# VALAYR_MAINNET_RATIO_1=0.0           # Mainnet task ratio — phase 1
# VALAYR_MAINNET_RATIO_2=0.3           # Mainnet task ratio — phase 2
# VALAYR_MAINNET_RATIO_3=0.6           # Mainnet task ratio — phase 3
# VALAYR_MIN_SEVERITY_1=0.0            # Min severity score — phase 1 (no floor)
# VALAYR_MIN_SEVERITY_2=0.1            # Min severity score — phase 2 (rewards zeroed below this)
# VALAYR_MIN_SEVERITY_3=0.2            # Min severity score — phase 3 (rewards zeroed below this)

# ── Logging ───────────────────────────────────────────────────────────────────
# EXPLOIT_LOG_LEVEL=INFO                          # Logging level (DEBUG, INFO, WARNING, ERROR)
# EXPLOIT_LOG_FILE=                               # Log file path (stdout if unset)

# ── Docker Sandbox ───────────────────────────────────────────────────────────
# VALAYR_DOCKER_IMAGE=ghcr.io/exploit-subnet/validator:v0.1.0  # Docker image for sandbox

# ── Bounty Reward Splits ─────────────────────────────────────────────────────
# VALAYR_MINER_SHARE=0.70                        # Miner reward share (default 70%)
# VALAYR_VALIDATOR_SHARE=0.20                     # Validator reward share (default 20%)
# VALAYR_TREASURY_SHARE=0.10                      # Treasury reward share (default 10%)
# VALAYR_TREASURY_ADDRESS=                        # Treasury contract address

# ── On-Chain Contract Addresses ──────────────────────────────────────────────
# VALAYR_RPC_URL=http://127.0.0.1:8545          # RPC endpoint for on-chain reads
# VALAYR_PROTOCOL_REGISTRY=                      # ProtocolRegistry contract address
# VALAYR_ADVERSARIAL_SCORING=                    # AdversarialScoring contract address
# VALAYR_EXPLOIT_REGISTRY=                       # ExploitRegistry contract address

# ── Discovery Engine ─────────────────────────────────────────────────────────
# VALAYR_SEED_TARGETS=                           # Comma-separated target contract addresses
# VALAYR_SEED_CHAIN_ID=1                         # Chain ID for discovery (default: Ethereum mainnet)

# ── On-Chain Signing (Validator / Deployer) ──────────────────────────────────
# ETH_PRIVATE_KEY=                               # Validator/deployer private key (NEVER commit)
# VALAYR_ADVERSARIAL_REGISTRY=                   # AdversarialRegistry contract address
# VALAYR_ADVERSARIAL_SCORING=                    # AdversarialScoring contract address

# ── Bounty / Treasury ───────────────────────────────────────────────────────
# VALAYR_MINER_SHARE=0.70              # Miner share of bounty rewards
# VALAYR_VALIDATOR_SHARE=0.20          # Validator share of bounty rewards
# VALAYR_TREASURY_SHARE=0.10           # Treasury share of bounty rewards
# VALAYR_TREASURY_ADDRESS=             # On-chain Treasury contract address
