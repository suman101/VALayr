{
  "annotations": {
    "list": []
  },
  "description": "VALayr Exploit Subnet — Validator Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Total Validations",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "validations_total",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }
    },
    {
      "title": "Valid Exploits",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "validations_valid",
          "legendFormat": "Valid"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 }
    },
    {
      "title": "Duplicates",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "duplicates_total",
          "legendFormat": "Duplicates"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 }
    },
    {
      "title": "Avg Severity Score",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "severity_score_sum / severity_score_count",
          "legendFormat": "Avg Severity"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 }
    },
    {
      "title": "Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Validation Throughput (per 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(validations_total[5m])",
          "legendFormat": "Total"
        },
        {
          "expr": "rate(validations_valid[5m])",
          "legendFormat": "Valid"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "title": "Validation Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(validation_latency_ms_sum[5m]) / rate(validation_latency_ms_count[5m])",
          "legendFormat": "Avg Latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "title": "Exploit Quality",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Severity Score Distribution",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "severity_score_sum / severity_score_count",
          "legendFormat": "Avg Severity"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 }
    },
    {
      "title": "Duplicate vs Unique Exploits",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(duplicates_total[5m])",
          "legendFormat": "Duplicates"
        },
        {
          "expr": "rate(validations_valid[5m]) - rate(duplicates_total[5m])",
          "legendFormat": "Unique"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 }
    },
    {
      "title": "Stage 3 — Adversarial Mode",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Invariants Submitted",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "invariants_submitted", "legendFormat": "Submitted" }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 }
    },
    {
      "title": "Challenges",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "challenges_total", "legendFormat": "Total" },
        { "expr": "invariants_broken", "legendFormat": "Broken" },
        { "expr": "invariants_held", "legendFormat": "Held" }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["valayr", "bittensor", "exploit-subnet"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "VALayr — Validator Dashboard",
  "uid": "valayr-validator",
  "version": 1
}
